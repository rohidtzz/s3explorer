{
  "appId": "com.s3explorer.app",
  "appName": "S3 Explorer",
  "webDir": "dist",
  "server": {
    "url": "https://s3.archives.my.id"
  },
  "android": {
    "allowMixedContent": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "StatusBar": {
      "overlaysWebView": false,
      "style": "LIGHT",
      "backgroundColor": "#13111C"
    },
    "Keyboard": {
      "resize": "ionic",
      "resizeOnFullScreen": true
    }
  }
}
